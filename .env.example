# Copy this file to `.env` and fill in the values. `.env` is gitignored; this
# template (no secrets) is committed so a fresh clone knows what to provide.

# Environment selector. Picks config/<step>/step.<ENV>.yaml. Use "dev" locally,
# "prod" in containers (which ship no .env). See the deployment-env skill.
ENV=dev

# Root for ALL private data (raw, curated, derived, gramps, …). A relative value
# anchors at the repo root; an absolute path is used as-is. Leave unset/empty to
# use the real "data/" tree. Set to "quickstart/data" to run against the
# committed dummy tree instead.
ANCESTRY_DATA_DIR=quickstart/data

# --- Nextcloud (download step) ---------------------------------------------
# Shared password for all Nextcloud public shares.
NEXTCLOUD_PASSWORD=

# Password for the encrypted zip archives downloaded from Nextcloud.
ZIP_PASSWORD=

# --- Cloudflare R2 (scripts/sync_private.py) -------------------------------
# Encrypted off-repo storage for private data. Create the bucket and an R2 API
# token (Object Read & Write) in the Cloudflare dashboard.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Encryption passphrase for uploaded blobs. Pick a strong one and keep it safe —
# losing it means the data on R2 is unrecoverable.
R2_PASSPHRASE=

# --- Third-party services ---------------------------------------------------
GITHUB_TOKEN=
HF_TOKEN=
DOCKERHUB_TOKEN=
ANTHROPIC_API_KEY=
WANDB_API_KEY=

# --- Label Studio local file serving ---------------------------------------
LABEL_STUDIO_LOCAL_FILES_SERVING_ENABLED=true
# Absolute path to the data/ directory on this machine.
LABEL_STUDIO_LOCAL_FILES_DOCUMENT_ROOT=
